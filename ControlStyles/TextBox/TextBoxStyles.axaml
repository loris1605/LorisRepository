<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ControlStyles">
  <Design.PreviewWith>
    <Border Padding="20">
      <local:UiTextBox/>
    </Border>
  </Design.PreviewWith>

  <Style Selector=":is(TextBox)">
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
    <Setter Property="FontFamily" Value="Verdana"/>
    <Setter Property="FontSize" Value="16"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Focusable" Value="True"/>
      <Setter Property="IsTabStop" Value="True"/>
  </Style>

    
    <Style Selector=":is(TextBox):focus-within">
        <Setter Property="Foreground" Value="Blue"/>
        <Setter Property="FontWeight" Value="Normal"/>
    </Style>

    <Style Selector=":is(TextBox):focus-within /template/ Border#PART_Border">
    <Setter Property="Background" Value="White"/>
</Style>

    <!--<Style Selector="TextBox.base:disabled" >
        <Setter Property="Background" Value="LightGray"/>
    </Style>-->

    <!--<Style Selector="TextBox.base:focus-within">
		<Setter Property="Foreground" Value="Red"/>
    </Style>-->



<!--<Style Selector="Border.TextBoxShadow:focus-within">
    <Setter Property="BoxShadow" Value="0 4 8 0 rgba(0,0,0,0.4)"/>
</Style>-->



 
</Styles>
