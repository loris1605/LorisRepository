<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ViewModels"
             xmlns:ui="using:ControlStyles"
             KeyboardNavigation.TabNavigation="Cycle"
             mc:Ignorable="d"
             Background="LightSteelBlue"
             d:DesignWidth="800"
             d:DesignHeight="800"
             x:DataType="vm:ConnectionViewModel"
             x:Class="Leonardo.ConnectionView">

    <!-- Main Grid -->
    <Grid >
		
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="3*"/> <!-- PopupBorder -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ui:PopupBorder VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Grid.Row="1"
                        Grid.Column="1">

            <Grid x:Name="PopupGrid">
				
                <Grid.RowDefinitions>
					<RowDefinition Height="50"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
					<ColumnDefinition />
                </Grid.ColumnDefinitions>

                <ui:UiTitolo x:Name="lblTitolo" 
                             FontSize="22" 
                             Text="CONNESSIONE AL DATABASE" 
                             SubTitolo="True"
                             Margin="30,0" 
                             HorizontalAlignment="Center"/>

                <Grid x:Name="InputGrid" 
                      Grid.Row="1"
                      Margin="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="5"/>
						<RowDefinition Height="Auto" MinHeight="35"/>
                        <RowDefinition Height="Auto" MinHeight="35"/>
                        <RowDefinition Height="Auto" MinHeight="35"/>
                        <RowDefinition Height="Auto" MinHeight="35"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="250"/>
                    </Grid.ColumnDefinitions>

                    <ui:UiLabelForGrid Text="SERVER : "
                                       Margin="10,10,0,10"
                                       Grid.Row="1"/>

                    <ui:UiComboBox x:Name="SqlCombo"
                                   Background="White"
                                   HorizontalContentAlignment="Center"
                                   Grid.Column="1"
                                   Grid.Row="1"
                                   Height="30"
                                   Margin="25,10,25,10"
                                   IsTabStop="False"
                                   Foreground="Black">
                    
                        <ui:UiComboBox.ItemTemplate>
							<DataTemplate>
                                <TextBlock Text="{Binding}" MinHeight="25"/>
                            </DataTemplate>
                        </ui:UiComboBox.ItemTemplate>
                    
                    </ui:UiComboBox>

                    <ui:UiLabelForGrid Text="NOME UTENTE : "
                                       Grid.Row="2"
                                       Margin="10,10,0,10"/>

                    <ui:UiTextBox Grid.Row="2" 
                                  x:Name="UserNameText"
                                  Grid.Column="1"
                                  Margin="25,2,25,2"
                                  VerticalAlignment="Center"/>

                    <ui:UiLabelForGrid Text="PASSWORD : "
                                       Grid.Row="3" 
                                       Margin="10,10,0,10"/>

                    <ui:UiTextBox x:Name="PasswordTextBox"
                                    Grid.Row="3"
                                    Grid.Column="1"
                                    Margin="25,2,25,2"
                                    VerticalAlignment="Center"/>

                    <ui:UiLabelForGrid Text="DATABASE : "
                                       Grid.Row="4" 
                                       Margin="10,10,0,10"/>

                    <ui:UiTextBox x:Name="DatabaseTextBox"
                                Grid.Row="4"
                                Grid.Column="1"
                                Margin="25,2,25,2"
                                VerticalAlignment="Center"/>
                
                </Grid>

                <Grid x:Name="ButtonGrid"
                             Grid.Row="2"
                             Margin="20">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <ui:UiButton Content=" CERCA " 
                                 x:Name="CercaButton"
                                 IsTabStop="False"
                                 Margin="20,2" 
                                 FontSize="14"
                                 Height="40"
                                 VerticalAlignment="Top"
                                 VerticalContentAlignment="Center"
                                 ToolTipText="CERCA SERVER"/>

                    <ui:UiButton Content=" CHECK " 
                                 Grid.Column="1"
                                 x:Name="CheckButton"
                                 Margin="20,2" 
                                 IsTabStop="False"
                                 Height="40"
                                 FontSize="14"
                                 VerticalAlignment="Top"
                                 VerticalContentAlignment="Center"
                                 ToolTipText="VERIFICA CONNESSIONE"/>

                    <ui:UiButton Content=" AVVIA " 
                                 x:Name="AvviaButton"
                                 Margin="20,2" 
                                 Grid.Column="2"
                                 IsTabStop="False"
                                 FontSize="14"
                                 VerticalAlignment="Top"
                                 Height="40"
                                 VerticalContentAlignment="Center"
                                 ToolTipText="AVVIA CONNESSIONE AL SERVER"/>
					
                </Grid>

                <TextBlock x:Name="InfoLabel"
                           Grid.Row="3"
                           Text="RICERCHE ISTANZE IN CORSO..."
                            VerticalAlignment="Center" 
                            HorizontalAlignment="Center"
                            FontFamily="Verdana" 
                            Foreground="LightBlue" 
                            Margin="10,50" 
                            FontSize="16" 
                            MinHeight="30"/>

            </Grid>

		    
        </ui:PopupBorder>
    </Grid>
  
</UserControl>
