<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:vm="using:ViewModels"
             xmlns:ui="using:ControlStyles"
             xmlns:r="using:ReactiveUI.Avalonia"
             KeyboardNavigation.TabNavigation="Cycle"
             Background="Transparent"
             x:CompileBindings="False"
             x:Class="Leonardo.PersonSearchView">

    <Grid x:Name="MainGrid" >
    
        <Grid.Resources>
            <!-- Azzera i vincoli di larghezza minimi del tema per il DatePicker -->
            <x:Double x:Key="DatePickerThemeMinWidth">0</x:Double>
            <x:Double x:Key="DatePickerThemeMaxWidth">1000</x:Double>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="3*"/> <!-- PopupBorder -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ui:PopupBorder VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Grid.Row="1"
                        Grid.Column="1">
        
            <Grid x:Name="PopupGrid">
            
                <Grid.RowDefinitions>
					<RowDefinition Height="50"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ui:UiTitolo x:Name="lblTitolo" 
                         FontSize="22" 
                         SubTitolo="True"
                         Margin="30,0" 
                         Text="Cerca Socio"
                         HorizontalAlignment="Center"/>

                <Viewbox Grid.Row="1"
                         Margin="10">
					
                    <Grid x:Name="InputGrid">
                    
                        <Grid.RowDefinitions>
                            <RowDefinition Height="5"/>
						    <RowDefinition Height="Auto" MinHeight="35"/>
                            <RowDefinition Height="Auto" MinHeight="35"/>
                            <RowDefinition Height="Auto" MinHeight="35"/>
                            <RowDefinition Height="Auto" MinHeight="35"/>
                            <RowDefinition Height="Auto" MinHeight="35"/>
                            <RowDefinition Height="Auto" MinHeight="35"/>
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" MinWidth="150"/>
                            <ColumnDefinition Width="*" MinWidth="180"/>
                            <ColumnDefinition Width="50" />
                        </Grid.ColumnDefinitions>

                        <ui:UiLabelForGrid 
                                Text="COGNOME :" 
                                Margin="10,10,0,10"
                                Grid.Row="1"/>

                        <ui:UiTextBox 
                                Grid.Row="1" 
                                x:Name="CognomeBox"
                                Grid.Column="1"
                                Margin="25,2,25,2"
                                VerticalAlignment="Center"/>

                        <ui:UiFindComboBox x:Name="CognomeCombo"
                            ComboType="String" 
                            Background="White"
                            Foreground="Black"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Grid.Column="2"
                            Grid.Row="1"
                            Height="30"
                            Margin="25,10,25,10"
                            IsTabStop="False"/>

                        <RadioButton x:Name="AnagraficaRadioButton"
                                     Grid.Row="1"
                                     Grid.Column="3"
                                     IsTabStop="False"
                                     HorizontalAlignment="Center" 
                                     VerticalAlignment="Center">
                            <RadioButton.RenderTransform>
                                <ScaleTransform ScaleX="2" ScaleY="2"/>
                            </RadioButton.RenderTransform>
                        </RadioButton>

                        
                        <ui:UiLabelForGrid 
                                Text="NOME :" 
                                Margin="10,10,0,10"
                                Grid.Row="2"/>

                        <ui:UiTextBox 
                                Grid.Row="2" 
                                x:Name="NomeBox"
                                Grid.Column="1"
                                Margin="25,2,25,2"
                                VerticalAlignment="Center"/>

                        <ui:UiFindComboBox x:Name="NomeCombo"
                            ComboType="String" 
                            Background="White"
                            Foreground="Black"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Grid.Column="2"
                            Grid.Row="2"
                            Height="30"
                            Margin="25,10,25,10"
                            IsTabStop="False"/>

                        <ui:UiLabelForGrid 
                                Text="DATA NASCITA :" 
                                Margin="10,10,0,10"
                                Grid.Row="3"/>

                        <ui:UiDatePicker x:Name="DataNascitaPicker"
                                     FontWeight="SemiBold" 
                                     VerticalAlignment="Center" 
                                     HorizontalAlignment="Stretch"
                                     Margin="25,2,25,2"
                                     Grid.Row="3"
                                     Grid.Column="1"/>

                        <ui:UiLabelForGrid 
                                Text="COD.SOCIO :" 
                                Margin="10,10,0,10"
                                Grid.Row="4"/>

                        <ui:UiIntegerTextBox Grid.Row="4" 
                                         x:Name="CodiceSocioBox"
                                         Grid.Column="1"
                                         Margin="25,2,25,2"
                                         VerticalAlignment="Center"/>

                        <RadioButton x:Name="SocioRadioButton"
                                     Grid.Row="4"
                                     Grid.Column="3"
                                     IsTabStop="False"
                                     HorizontalAlignment="Center" 
                                     VerticalAlignment="Center">
                            <!--<RadioButton.RenderTransform>
                                <ScaleTransform ScaleX="2" ScaleY="2"/>
                            </RadioButton.RenderTransform>-->
                        </RadioButton>

                        <ui:UiLabelForGrid 
                                Text="N° TESSERA :" 
                                Margin="10,10,0,10"
                                Grid.Row="5"/>

                        <ui:UiIntegerTextBox Grid.Row="5" 
                                         x:Name="NumeroTesseraBox"
                                         Grid.Column="1"
                                         Margin="25,2,25,2"
                                         VerticalAlignment="Center"/>

                        <RadioButton x:Name="TesseraRadioButton"
                                     Grid.Row="5"
                                     Grid.Column="3"
                                     IsTabStop="False"
                                     HorizontalAlignment="Center" 
                                     VerticalAlignment="Center">
                            <!--<RadioButton.RenderTransform>
                                <ScaleTransform ScaleX="2" ScaleY="2"/>
                            </RadioButton.RenderTransform>-->
                        </RadioButton>

                    
                    </Grid>


                </Viewbox>
            
            </Grid>
        
        </ui:PopupBorder>
    
    </Grid>
  
</UserControl>
