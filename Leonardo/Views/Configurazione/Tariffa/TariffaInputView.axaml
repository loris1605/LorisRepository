<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ViewModels"
             xmlns:ui="using:ControlStyles"
             xmlns:r="using:ReactiveUI.Avalonia"
             xmlns:lc="using:Leonardo"
             KeyboardNavigation.TabNavigation="Cycle"
             Background="Transparent"
             x:CompileBindings="False"
             x:DataType="vm:TariffaInputBase"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Leonardo.TariffaInputView">

    <Grid x:Name="MainGrid" >
    
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="3*"/> <!-- PopupBorder -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ui:PopupBorder VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Grid.Row="1"
                        Grid.Column="1">
        
            <Grid x:Name="PopupGrid">
            
                <Grid.RowDefinitions>
					<RowDefinition Height="50"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ui:UiTitolo x:Name="lblTitolo" 
                         FontSize="22" 
                         SubTitolo="True"
                         Margin="30,0" 
                         HorizontalAlignment="Center"/>

                <Viewbox Grid.Row="1"
                         Margin="10">
                
                    <Grid x:Name="InputGrid">
                    
                        <Grid.RowDefinitions>
                            <RowDefinition Height="5"/>
					    	<RowDefinition Height="Auto" MinHeight="35"/>
                            <RowDefinition Height="Auto" MinHeight="35"/>
                            <RowDefinition Height="Auto" MinHeight="35"/>
                            
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="250"/>
                        </Grid.ColumnDefinitions>

                        <ui:UiLabelForGrid Text="NOME :" 
                                       Margin="10,10,0,10"
                                       Grid.Row="1"/>

                        <ui:UiTextBox Grid.Row="1" 
                                  x:Name="NomeBox"
                                  Grid.Column="1"
                                  Margin="25,2,25,2"
                                  VerticalAlignment="Center"/>

                        <ui:UiLabelForGrid Text="ETICHETTA :" 
                                       Margin="10,10,0,10"
                                       Grid.Row="2"/>

                        <ui:UiTextBox Grid.Row="2" 
                                  x:Name="EtichettaBox"
                                  Grid.Column="1"
                                  Margin="25,2,25,2"
                                  VerticalAlignment="Center"/>

                        <ui:UiLabelForGrid Text="PREZZO :" 
                                       Margin="10,10,0,10"
                                       Grid.Row="3"/>

                        <NumericUpDown Value="{Binding PrezzoTariffa}" 
                                       x:Name="PrezzoBox"
                                       Grid.Row="3"
                                       Grid.Column="1"
                                       FormatString="C2" 
                                       Minimum="0" 
                                       Increment="0.5"
                                       Margin="25,2,25,2"
                                       ParsingNumberStyle="Currency">
                            <!--<NumericUpDown.InnerLeftContent>
                                <TextBlock Text="€" VerticalAlignment="Center" Margin="5,0"/>
                            </NumericUpDown.InnerLeftContent>-->
                        </NumericUpDown>


         
                    </Grid>
                
                </Viewbox>

                <TextBlock x:Name="InfoLabel"
                           Grid.Row="2"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="20,10">

                    <TextBlock.Styles>
                        <Style Selector="TextBlock">
                            <Style.Animations>
                                <Animation Duration="0:0:1" 
                                           IterationCount="Infinite" 
                                           PlaybackDirection="Alternate">
                                    <KeyFrame KeyTime="0:0:0">
                                        <Setter Property="Opacity" Value="1.0"/>
                                    </KeyFrame>
                                    <KeyFrame KeyTime="0:0:1">
                                        <Setter Property="Opacity" Value="0.3"/>
                                    </KeyFrame>
                                </Animation>
                            </Style.Animations>
                        </Style>
                    </TextBlock.Styles>

                </TextBlock>

                <lc:InputSaveBox x:Name="InputSaveBox"
                                 Grid.Row="3"
                                 Margin="20"/>
            
            </Grid>
        
        </ui:PopupBorder>
    
    </Grid>
  
</UserControl>
